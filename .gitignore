hs_err_pid*
replay_pid*

# Maven
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
# https://github.com/takari/maven-wrapper#usage-without-binary-jar
.mvn/wrapper/maven-wrapper.jar

# IDE
.idea/
*.iml
*.iws
.vscode/
.settings/
.project
.classpath
bin/

# OS
.DS_Store
Thumbs.db

# Node
node_modules/
dist/

# ==========================================
# 敏感信息 - 环境变量 & 密钥文件
# ==========================================
# 环境变量文件（包含所有密钥）
.env
.env.local
.env.prod
.env.test

# 但.env.example是模板文件，需要跟踪
!.env.example

# 后端环境变量
backend/.env
backend/.env.local
backend/.env.prod
backend/.env.test

# 后端.env.example是模板文件，需要跟踪
!backend/.env.example

# 支付宝 PEM 私钥/公钥文件（已从 application.yml 移到独立文件）
backend/certs/*.pem
!backend/certs/*.example.pem

# Natapp 隧道配置（含 authtoken）及二进制
config.ini
config.local.ini
natapp.exe

# Claude 记忆文件（包含本项目特有的敏感信息）
.claude/memory/

# Spring Boot
*.pid
*.stream

# 隐私信息存放位置汇总（记录了所有密钥文件位置）
SECRETS_MAP.md
