# ============================================
# Movie Website - 环境变量模板
# 复制此文件为 .env 并填入你的实际密钥
# cp .env.example .env
# ============================================

# --- 数据库配置 ---
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=movie_website
MYSQL_USERNAME=root
MYSQL_PASSWORD=your_mysql_password

# --- Redis 配置 ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_PASSWORD=

# --- Neo4j 图数据库 ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password

# --- DeepSeek AI (如果用不到可留空) ---
DEEPSEEK_API_KEY=sk-your_deepseek_api_key_here

# --- JWT 密钥配置（生产环境请更换为随机字符串） ---
JWT_SECRET=change_this_to_a_random_secret_key
JWT_EXPIRATION=86400000

# --- 支付宝沙箱配置 ---
ALIPAY_APP_ID=your_alipay_app_id
ALIPAY_PRIVATE_KEY_PATH=file:./certs/alipay-private-key.pem
ALIPAY_PUBLIC_KEY_PATH=file:./certs/alipay-public-key.pem
ALIPAY_NOTIFY_URL=http://your-natapp-domain.natappfree.cc/api/payment/notify
ALIPAY_RETURN_URL=http://localhost:5173/payment/result
ALIPAY_GATEWAY_URL=https://openapi-sandbox.dl.alipaydev.com/gateway.do

# --- Natapp 隧道配置 ---
NATAPP_AUTH_TOKEN=your_natapp_authtoken
